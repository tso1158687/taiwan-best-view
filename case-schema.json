{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://taiwan-best-view.local/case-schema.json",
  "title": "Taiwan Best View Case Draft",
  "type": "object",
  "required": [
    "jurisdiction",
    "violationType",
    "plate",
    "occurredAt",
    "district",
    "road",
    "fact",
    "description",
    "files",
    "attachments",
    "status"
  ],
  "properties": {
    "jurisdiction": {
      "type": "string",
      "enum": ["taipei", "new_taipei"]
    },
    "violationType": {
      "type": "string",
      "enum": ["illegal_parking"]
    },
    "plate": {
      "type": "string"
    },
    "occurredAt": {
      "type": "string",
      "description": "Taiwan local timestamp with +08:00 offset."
    },
    "district": {
      "type": "string"
    },
    "road": {
      "type": "string"
    },
    "addressNote": {
      "type": "string"
    },
    "fact": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "files": {
      "type": "array",
      "description": "Submission-ready file names.",
      "items": {
        "type": "string"
      },
      "maxItems": 5
    },
    "attachments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "originalName",
          "submissionName",
          "originalExtension",
          "submissionExtension",
          "size",
          "type",
          "needsConversion",
          "conversionStatus",
          "exifStatus",
          "acceptedByOfficial"
        ],
        "properties": {
          "originalName": {
            "type": "string"
          },
          "submissionName": {
            "type": "string"
          },
          "originalExtension": {
            "type": "string"
          },
          "submissionExtension": {
            "type": "string"
          },
          "size": {
            "type": "integer",
            "minimum": 0
          },
          "type": {
            "type": "string"
          },
          "needsConversion": {
            "type": "boolean"
          },
          "conversionStatus": {
            "type": "string",
            "enum": ["not_required", "pending", "converted", "failed"]
          },
          "exifStatus": {
            "type": "string",
            "enum": ["not_checked", "pending", "preserved", "partial", "missing", "sidecar"]
          },
          "gpsStatus": {
            "type": "string",
            "enum": ["not_checked", "present", "missing"]
          },
          "capturedAt": {
            "type": "string"
          },
          "latitude": {
            "type": ["number", "null"]
          },
          "longitude": {
            "type": ["number", "null"]
          },
          "renderedWidth": {
            "type": ["number", "null"]
          },
          "renderedHeight": {
            "type": ["number", "null"]
          },
          "acceptedByOfficial": {
            "type": "boolean"
          },
          "verificationSource": {
            "type": "string"
          },
          "note": {
            "type": "string"
          }
        }
      },
      "maxItems": 5
    },
    "locationAssistance": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["needs_review", "manual_required"]
        },
        "missingGpsAttachments": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "candidates": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["source", "confidence", "label", "latitude", "longitude", "evidenceFiles", "maps", "note"],
            "properties": {
              "source": {
                "type": "string"
              },
              "confidence": {
                "type": "string",
                "enum": ["needs_review"]
              },
              "label": {
                "type": "string"
              },
              "latitude": {
                "type": "number"
              },
              "longitude": {
                "type": "number"
              },
              "evidenceFiles": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "maps": {
                "type": "object",
                "properties": {
                  "apple": {
                    "type": "string"
                  },
                  "google": {
                    "type": "string"
                  }
                }
              },
              "note": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "photoAnalysis": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string"
        },
        "engine": {
          "type": "string"
        },
        "plateCandidates": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "text": {
                "type": "string"
              },
              "confidence": {
                "type": "number"
              },
              "sourceText": {
                "type": "string"
              }
            }
          }
        },
        "locationTextCandidates": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "text": {
                "type": "string"
              },
              "confidence": {
                "type": "number"
              }
            }
          }
        },
        "results": {
          "type": "array"
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "fieldSuggestions": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["needs_review", "empty"]
        },
        "plate": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/fieldSuggestion"
          }
        },
        "road": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/fieldSuggestion"
          }
        },
        "addressNote": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/fieldSuggestion"
          }
        }
      }
    },
    "status": {
      "type": "string",
      "enum": ["draft", "ready_for_review", "submitted"]
    },
    "updatedAt": {
      "type": "string"
    }
  },
  "$defs": {
    "fieldSuggestion": {
      "type": "object",
      "properties": {
        "field": {
          "type": "string"
        },
        "value": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "confidence": {
          "type": "number"
        },
        "evidence": {
          "type": "string"
        },
        "maps": {
          "type": "object"
        },
        "requiresReview": {
          "type": "boolean"
        }
      }
    }
  }
}
